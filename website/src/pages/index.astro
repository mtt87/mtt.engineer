---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("posts")).sort(
  (a, b) => b.data.createdAt.valueOf() - a.data.createdAt.valueOf(),
);
---

<BaseLayout>
  <h2 class="mb-4">Hello 👋,</h2>
  <p>
    I'm <strong>Mattia</strong>, a <strong>software engineer</strong> with {
      new Date().getFullYear() - 2012
    }+ years of experience, currently based in London, UK.
  </p>

  <p>
    I work best with <strong>TypeScript</strong> across the full stack while specializing
    in the frontend, where I've been using React for years.
  </p>
  <p>
    I started also using <strong>Rust</strong> since 2024 and while I've built a
    couple of services, I still consider myself a beginner.
  </p>

  <p>
    These days, a lot of my work is <strong>AI-assisted</strong>, and I've used <strong
      >Claude Code</strong
    >
    heavily over the past year.
  </p>

  <p>
    I'm the type of engineer who thrives at the <strong
      >intersection of product and code</strong
    >; I genuinely enjoy talking to users, understanding their problems, and
    shaping solutions that address real needs.
  </p>

  <p>
    I'm a big fan of <strong>home automation</strong> and love finding new ways to
    use my collection of <strong>Raspberry Pis</strong>.
  </p>

  <p>
    I'm a Mac videogamer, mostly switching between <strong
      >World of Warcraft</strong
    > and <strong>League of Legends</strong> but occasionally enjoying single player
    cozy games on my PlayStation 5.
  </p>

  <p>
    My CV is available in <a class="hover:underline" href="mattia_asti.pdf"
      >PDF</a
    >, <a class="hover:underline" href="/cv">HTML</a> or <a
      class="hover:underline"
      href="/cv.json">JSON</a
    >.
  </p>

  <p>
    <small>Opinions expressed are my own and not those of my employer.</small>
  </p>

  <hr />

  <ul class="flex flex-col gap-4">
    {
      posts.map((post) => (
        <li class="flex flex-col gap-1 no-underline">
          <a href={`/posts/${post.id}`}>
            <h4>{post.data.title}</h4>
          </a>
          <p>{post.data.description}</p>
        </li>
      ))
    }
  </ul>
</BaseLayout>
